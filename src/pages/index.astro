---
import Layout from '../layouts/Layout.astro';

const phone = '(02) 6251 1556';
const phoneHref = 'tel:+61262511556';
const address = '3/68 Josephson Street, Belconnen ACT 2617';

const services = [
  { t: 'Full-Service Wash & Dry', d: 'Our friendly team washes and dries your laundry for you on modern high-capacity machines.', i: 'washer' },
  { t: 'Wash, Dry & Fold', d: "Short on time? Leave it with us and we'll wash, dry and fold it for you.", i: 'fold' },
  { t: 'Dry Cleaning Drop Off', d: 'Convenient dry-cleaning collection and drop-off — no extra trip.', i: 'hanger' },
  { t: 'Commercial Laundry', d: 'Reliable solutions for businesses, Airbnb hosts, tradies and hospitality.', i: 'commercial' },
  { t: 'Extra Large Machines', d: 'Perfect for doonas, blankets, pet bedding, curtains, rugs and big loads.', i: 'basket' },
  { t: 'Pick Up & Delivery', d: 'A convenient collection and delivery service for when you need it.', i: 'truck' },
];

const features = [
  { t: 'Warm & Welcoming', d: 'A clean, comfortable space designed for Canberra winters.' },
  { t: 'Modern Equipment', d: 'Fast, reliable machines delivering great results every time.' },
  { t: 'Local & Trusted', d: 'Proudly serving Belconnen and the wider Canberra community.' },
  { t: 'Easy Parking', d: 'Plenty of parking right out the front for an easy visit.' },
  { t: 'Open 7 Days', d: 'Early starts and late finishes — laundry when it suits you.' },
];

const perfect = [
  { img: 'sports', t: 'Sports Teams', d: 'Keep uniforms, training gear and team apparel clean, fresh and game-ready.', i: '<ellipse cx="12" cy="12" rx="9.5" ry="6.5"/><path d="M9 9l6 6M15 9l-6 6"/>' },
  { img: 'gyms', t: 'Gyms & Fitness Studios', d: 'Towels, cleaning cloths and workout gear washed quickly and professionally.', i: '<path d="M3 9v6M6 7v10M18 7v10M21 9v6M6 12h12"/>' },
  { img: 'business', t: 'Businesses', d: 'Reliable laundry solutions for offices, hospitality, childcare centres and local businesses.', i: '<rect x="4" y="3" width="16" height="18" rx="1"/><path d="M8 7h2M14 7h2M8 11h2M14 11h2M8 15h2M14 15h2"/>' },
  { img: 'airbnb', t: 'Airbnb Hosts', d: 'Fresh, high-quality linen that helps you deliver 5-star stays.', i: '<path d="M3 11l9-7 9 7"/><path d="M5 10v9h14v-9"/><path d="M10 19v-5h4v5"/>' },
  { img: 'doonas', t: 'Doonas & Blankets', d: 'Large items, professionally washed and dried with care.', i: '<path d="M12 3 2 8l10 5 10-5Z"/><path d="M2 12l10 5 10-5"/><path d="M2 16l10 5 10-5"/>' },
  { img: 'family', t: 'Large Family Loads', d: 'Big loads are no problem. More capacity, more time for what matters.', i: '<circle cx="9" cy="8" r="3"/><circle cx="17" cy="9" r="2"/><path d="M3 19c0-3 3-5 6-5s6 2 6 5"/><path d="M15.5 14c2 0 5 1 5 4"/>' },
];

const hours = [
  ['Monday – Friday', '6:00am – 9:00pm'],
  ['Saturday', '7:00am – 9:00pm'],
  ['Sunday', '8:00am – 8:00pm'],
  ['Public Holidays', '8:00am – 8:00pm'],
];

const icons = {
  washer: '<circle cx="12" cy="13" r="6"/><circle cx="12" cy="13" r="2.5"/><line x1="6" y1="6" x2="6" y2="6.01"/><line x1="9" y1="6" x2="9" y2="6.01"/>',
  fold: '<path d="M3 7h18M3 12h18M3 17h18"/>',
  hanger: '<path d="M12 6a2 2 0 1 1 1.4 1.9L12 9v2"/><path d="M12 11 4 17h16Z"/>',
  commercial: '<rect x="4" y="3" width="16" height="18" rx="1"/><path d="M8 7h2M14 7h2M8 11h2M14 11h2M8 15h2M14 15h2"/>',
  basket: '<path d="M4 9h16l-1.5 11h-13Z"/><path d="M8 9 10 4M16 9 14 4"/>',
  truck: '<rect x="2" y="7" width="12" height="9"/><path d="M14 10h4l3 3v3h-7Z"/><circle cx="7" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/>',
};
---
<Layout
  title="Belconnen Laundromat | Full-Service Laundry in Belconnen, ACT"
  description="Belconnen Laundromat — full-service wash & dry, wash-dry-fold, dry cleaning and commercial laundry. Our friendly team does it for you. Open 7 days at 3/68 Josephson St, Belconnen ACT. Come in cold. Leave warm.">
  <link rel="preload" as="image" href="/hero.png" slot="head" />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'LaundryService',
    name: 'Belconnen Laundromat',
    image: 'https://belconnenlaundromat.com.au/logo.png',
    telephone: '+61262511556',
    url: 'https://belconnenlaundromat.com.au',
    address: { '@type': 'PostalAddress', streetAddress: '3/68 Josephson Street', addressLocality: 'Belconnen', addressRegion: 'ACT', postalCode: '2617', addressCountry: 'AU' },
    openingHours: ['Mo-Fr 06:00-21:00', 'Sa 07:00-21:00', 'Su 08:00-20:00'],
    slogan: 'Come in cold. Leave warm.',
  })} />

  <header class="site-header">
    <a class="brand" href="/"><img src="/logo.png" alt="Belconnen Laundromat" width="130" /></a>
    <nav>
      <a href="#services">Services</a>
      <a href="#why">Why Us</a>
      <a href="#visit">Visit</a>
      <a class="btn btn-call" href={phoneHref}>Call {phone}</a>
    </nav>
  </header>

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-overlay"></div>
      <div class="hero-text">
        <span class="eyebrow">Full-Service Laundry · Belconnen ACT</span>
        <h1>Come In Cold.<br /><span class="accent">Leave Warm.</span></h1>
        <p>A clean, welcoming laundromat with modern machines and friendly service — built for Canberra. We do the laundry. You do life.</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={phoneHref}>Call Now</a>
          <a class="btn btn-ghost" href="#services">Our Services</a>
        </div>
        <p class="hero-tag">Clean clothes. Warm washes. Friendly service.</p>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="section">
      <div class="section-head">
        <span class="kicker">Our Services</span>
        <h2>Everything your laundry needs</h2>
      </div>
      <div class="grid grid-3">
        {services.map((s) => (
          <article class="card">
            <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.i]} /></span>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- WHY -->
    <section id="why" class="section section-dark">
      <div class="section-head">
        <span class="kicker">Why Choose Us</span>
        <h2>Why locals love Belconnen Laundromat</h2>
      </div>
      <div class="grid grid-5 features">
        {features.map((f) => (
          <div class="feature">
            <h3>{f.t}</h3>
            <p>{f.d}</p>
          </div>
        ))}
      </div>
      <div class="perfect">
        <span class="perfect-label">Perfect for</span>
        <div class="grid grid-3 perfect-grid">
          {perfect.map((p) => (
            <article class="pcard">
              <img src={`/perfect/${p.img}.jpg`} alt={p.t} loading="lazy" />
              <div class="pcard-body">
                <span class="picon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={p.i} /></span>
                <h3>{p.t}</h3>
                <p>{p.d}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* PROMO — disabled for now, we don't run this discount yet
    <section class="promo">
      <div>
        <h2>First Wash <strong>20% Off</strong></h2>
        <p>On your first wash or dry with us. New customers only.</p>
      </div>
      <a class="btn btn-dark" href={phoneHref}>Claim Your Discount</a>
    </section>
    */}

    <!-- VISIT -->
    <section id="visit" class="section visit">
      <div class="section-head">
        <span class="kicker">Visit Us</span>
        <h2>Open 7 days in the heart of Belconnen</h2>
      </div>
      <div class="visit-grid">
        <div class="visit-card">
          <h3>Find Us</h3>
          <p>{address}</p>
          <p class="muted">Plenty of parking right out the front!</p>
          <h3>Get In Touch</h3>
          <p><a href={phoneHref}>{phone}</a></p>
          <p><a href="https://belconnenlaundromat.com.au">belconnenlaundromat.com.au</a></p>
          <h3>Payments</h3>
          <ul class="payments">
            <li>Card</li><li>Tap &amp; Pay</li><li>Cash</li>
          </ul>
        </div>
        <div class="visit-card hours">
          <h3>Opening Hours</h3>
          <table>
            {hours.map(([d, t]) => <tr><td>{d}</td><td>{t}</td></tr>)}
          </table>
        </div>
      </div>
      <iframe
        class="map"
        title="Belconnen Laundromat location on Google Maps"
        src="https://www.google.com/maps?q=3%2F68%20Josephson%20Street%2C%20Belconnen%20ACT%202617&output=embed"
        loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </section>
  </main>

  <footer class="site-footer">
    <img src="/logo.png" alt="Belconnen Laundromat" width="160" />
    <p class="footer-tag">Come in cold. Leave warm.</p>
    <p class="footer-meta">{address} · <a href={phoneHref}>{phone}</a></p>
    <div class="socials">
      <a href="https://www.facebook.com/belconnenlaundromat" target="_blank" rel="noopener" aria-label="Belconnen Laundromat on Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3.5l.5-4h-4V3.2c0-1 .3-1.7 1.8-1.7H18.5V-.1A24 24 0 0 0 15.8-.2C13.2-.2 11.4 1.4 11.4 4.3V5H8v4h3.4v11h3.6z" transform="translate(0 2)"/></svg>
      </a>
      <a href="https://www.instagram.com/belconnenlaundromat" target="_blank" rel="noopener" aria-label="Belconnen Laundromat on Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
      </a>
    </div>
    <p class="copyright">© Belconnen Laundromat. Proudly local.</p>
  </footer>
</Layout>

<style is:global>
  :root {
    --navy: #1B2430; --slate: #647B8C; --light: #8FA4B3;
    --terra: #D07A5C; --cream: #F6F2EE; --grey: #D9D3CC;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: var(--navy); background: var(--cream); line-height: 1.6;
  }
  h1, h2, h3 { line-height: 1.15; letter-spacing: -0.01em; }
  a { color: inherit; text-decoration: none; }
  img { display: block; height: auto; max-width: 100%; }

  .btn {
    display: inline-block; padding: 0.85rem 1.6rem; border-radius: 8px;
    font-weight: 700; font-size: 0.95rem; transition: transform .15s, opacity .15s;
  }
  .btn:hover { transform: translateY(-2px); opacity: .92; }
  .btn-primary, .btn-call { background: var(--terra); color: #fff; }
  .btn-ghost { border: 2px solid #fff; color: #fff; }
  .btn-dark { background: var(--navy); color: var(--cream); }

  /* HEADER */
  .site-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.75rem 5vw; background: var(--cream);
    position: sticky; top: 0; z-index: 10; border-bottom: 1px solid var(--grey);
  }
  .site-header nav { display: flex; align-items: center; gap: 1.75rem; font-weight: 600; }
  .site-header nav a:not(.btn):hover { color: var(--terra); }

  /* HERO */
  .hero {
    position: relative; display: flex; align-items: center; min-height: 78vh;
    padding: 6rem 5vw; overflow: hidden;
    background: url('/hero.png') center/cover no-repeat;
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(100deg, rgba(27,36,48,.88) 0%, rgba(27,36,48,.66) 45%, rgba(27,36,48,.3) 100%);
  }
  .hero-text { position: relative; z-index: 1; }
  .eyebrow { color: var(--light); font-weight: 700; letter-spacing: .08em; text-transform: uppercase; font-size: .8rem; }
  .hero h1 { font-size: clamp(2.6rem, 6vw, 4.5rem); font-weight: 800; margin: 1rem 0; text-transform: uppercase; color: #fff; }
  .hero h1 .accent { color: var(--terra); }
  .hero-text > p { font-size: 1.15rem; max-width: 40ch; color: rgba(246,242,238,.9); }
  .hero-cta { display: flex; gap: 1rem; margin: 1.75rem 0 1rem; flex-wrap: wrap; }
  .hero-tag { font-style: italic; color: var(--light); font-weight: 600; }

  /* SECTIONS */
  .section { padding: 5rem 5vw; }
  .section-head { text-align: center; margin-bottom: 3rem; }
  .kicker { color: var(--terra); font-weight: 700; letter-spacing: .1em; text-transform: uppercase; font-size: .8rem; }
  .section-head h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 800; margin-top: .5rem; }

  .grid { display: grid; gap: 1.5rem; }
  .grid-3 { grid-template-columns: repeat(3, 1fr); }
  .grid-5 { grid-template-columns: repeat(5, 1fr); }

  .card {
    background: #fff; border: 1px solid var(--grey); border-radius: 14px; padding: 2rem;
    transition: transform .2s, box-shadow .2s;
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 16px 32px rgba(27,36,48,.1); }
  .icon {
    display: grid; place-items: center; width: 56px; height: 56px; border-radius: 50%;
    background: var(--cream); color: var(--slate); margin-bottom: 1.2rem;
  }
  .icon svg { width: 28px; height: 28px; }
  .card h3 { font-size: 1.2rem; margin-bottom: .5rem; }
  .card p { color: #4a5663; }

  /* WHY (dark) */
  .section-dark { background: var(--navy); color: var(--cream); }
  .section-dark .section-head h2 { color: var(--cream); }
  .features .feature { text-align: center; padding: 1rem; }
  .feature h3 { color: var(--terra); font-size: 1.05rem; margin-bottom: .4rem; }
  .feature p { color: var(--light); font-size: .95rem; }
  .perfect { margin-top: 3.5rem; padding-top: 2.5rem; border-top: 1px solid #2c3947; }
  .perfect-label { display: block; text-align: center; text-transform: uppercase; letter-spacing: .1em; color: var(--light); margin-bottom: 1.75rem; font-weight: 700; font-size: .85rem; }
  .pcard {
    position: relative; border-radius: 14px; overflow: hidden; min-height: 280px;
    display: flex; align-items: flex-end;
  }
  .pcard img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .pcard-body {
    position: relative; padding: 1.5rem; color: var(--cream);
    background: linear-gradient(to top, rgba(27,36,48,.96) 45%, rgba(27,36,48,.5) 75%, transparent);
    width: 100%;
  }
  .picon {
    display: grid; place-items: center; width: 46px; height: 46px; border-radius: 50%;
    background: rgba(255,255,255,.12); border: 1.5px solid var(--cream); color: var(--cream); margin-bottom: .9rem;
  }
  .picon svg { width: 24px; height: 24px; }
  .pcard-body h3 { font-size: 1.1rem; text-transform: uppercase; letter-spacing: .03em; margin-bottom: .4rem; }
  .pcard-body p { color: var(--light); font-size: .9rem; line-height: 1.5; }

  /* PROMO */
  .promo {
    background: var(--terra); color: #fff; padding: 2.5rem 5vw;
    display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap;
  }
  .promo h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 700; }
  .promo h2 strong { font-weight: 800; }
  .promo p { opacity: .95; }

  /* VISIT */
  .visit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; max-width: 900px; margin: 0 auto; }
  .visit-card { background: #fff; border: 1px solid var(--grey); border-radius: 14px; padding: 2.5rem; }
  .visit-card h3 { color: var(--slate); font-size: 1rem; text-transform: uppercase; letter-spacing: .06em; margin: 1.5rem 0 .5rem; }
  .visit-card h3:first-child { margin-top: 0; }
  .visit-card a:hover { color: var(--terra); }
  .visit-card .muted { color: var(--slate); font-style: italic; }
  .hours table { width: 100%; border-collapse: collapse; }
  .hours td { padding: .6rem 0; border-bottom: 1px solid var(--grey); }
  .hours td:last-child { text-align: right; font-weight: 700; color: var(--terra); }
  .payments { list-style: none; display: flex; flex-wrap: wrap; gap: .5rem; }
  .payments li { background: var(--cream); border: 1px solid var(--grey); color: var(--navy); padding: .35rem .85rem; border-radius: 999px; font-weight: 600; font-size: .85rem; }
  .map { width: 100%; max-width: 900px; height: 320px; border: 0; border-radius: 14px; margin: 1.5rem auto 0; display: block; }

  /* FOOTER */
  .site-footer { background: var(--navy); color: var(--cream); text-align: center; padding: 3.5rem 5vw; }
  .site-footer img { margin: 0 auto 1rem; background: var(--cream); border-radius: 12px; padding: .5rem 1rem; }
  .footer-tag { font-style: italic; color: var(--terra); font-weight: 700; margin-bottom: .75rem; }
  .footer-meta { color: var(--light); }
  .footer-meta a:hover { color: var(--terra); }
  .copyright { color: var(--slate); font-size: .85rem; margin-top: 1rem; }
  .socials { display: flex; gap: 1rem; justify-content: center; margin: 1.25rem 0; }
  .socials a { display: grid; place-items: center; width: 42px; height: 42px; border-radius: 50%; background: #28333f; color: var(--cream); transition: background .15s, transform .15s; }
  .socials a:hover { background: var(--terra); transform: translateY(-2px); }
  .socials svg { width: 20px; height: 20px; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .grid-3 { grid-template-columns: repeat(2, 1fr); }
    .grid-5 { grid-template-columns: repeat(2, 1fr); }
    .hero { min-height: 70vh; }
    .visit-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .grid-3, .grid-5 { grid-template-columns: 1fr; }
    .site-header nav { gap: .9rem; font-size: .9rem; }
    .site-header nav a:not(.btn) { display: none; }
  }
</style>
